<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Devexa\AiRecommendation\Block\Recommendations"
                   name="devexa.ai.recommendation.cart"
                   template="Devexa_AiRecommendation::luma/recommendations.phtml"
                   after="-">
                <arguments>
                    <argument name="recommendation_context" xsi:type="string">cart</argument>
                    <argument name="display_mode" xsi:type="string">carousel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
