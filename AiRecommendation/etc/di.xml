<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Devexa\AiRecommendation\Api\RecommendationEngineInterface"
                type="Devexa\AiRecommendation\Model\RecommendationEngine"/>
    <preference for="Devexa\AiRecommendation\Api\EventTrackerInterface"
                type="Devexa\AiRecommendation\Model\EventTracker"/>

    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="devexa_recommendations_prefetch" xsi:type="object">Devexa\AiRecommendation\Console\Command\PreFetchCommand</item>
            </argument>
        </arguments>
    </type>
</config>
