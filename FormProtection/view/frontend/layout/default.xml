<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="devexa.form.protection.smartshield"
                   template="Devexa_FormProtection::smartshield.phtml">
                <arguments>
                    <argument name="protection_view_model" xsi:type="object">Devexa\FormProtection\ViewModel\Protection</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
