<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <devexa_smart_search>
            <general>
                <enabled>0</enabled>
                <min_chars>3</min_chars>
                <debounce_ms>300</debounce_ms>
                <max_results>5</max_results>
            </general>
            <sections>
                <products_enabled>1</products_enabled>
                <products_limit>5</products_limit>
                <categories_enabled>1</categories_enabled>
                <categories_limit>3</categories_limit>
                <pages_enabled>1</pages_enabled>
                <pages_limit>3</pages_limit>
                <ai_enabled>0</ai_enabled>
                <ai_limit>4</ai_limit>
            </sections>
            <ai>
                <environment>production</environment>
                <api_endpoint>https://api.devexa.ro/v1/search</api_endpoint>
                <api_endpoint_dev>https://host.docker.internal:3443/v1/search</api_endpoint_dev>
                <api_key/>
            </ai>
            <layout>
                <product_display>list</product_display>
                <product_columns>4</product_columns>
                <sidebar_position>left</sidebar_position>
                <popup_max_width>800</popup_max_width>
            </layout>
            <filters>
                <exclude_words>the,and,or,a,an,is,it,to,of,in,for,on,with</exclude_words>
                <in_stock_only>0</in_stock_only>
                <min_price>0</min_price>
                <max_price>0</max_price>
                <exclude_categories/>
                <exclude_skus/>
            </filters>
            <appearance>
                <highlight_color>#7c3aed</highlight_color>
                <show_product_image>1</show_product_image>
                <show_product_price>1</show_product_price>
                <show_product_sku>0</show_product_sku>
                <show_product_description>0</show_product_description>
            </appearance>
        </devexa_smart_search>
    </default>
</config>
