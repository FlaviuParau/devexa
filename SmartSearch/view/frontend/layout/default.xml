<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Add SmartSearch after the default search (Luma) -->
        <referenceContainer name="header-wrapper">
            <block class="Magento\Framework\View\Element\Template"
                   name="devexa.smart.search"
                   template="Devexa_SmartSearch::luma/search.phtml"
                   after="top.search">
                <arguments>
                    <argument name="search_config" xsi:type="object">Devexa\SmartSearch\ViewModel\SearchConfig</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
