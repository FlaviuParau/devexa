<?php
/**
 * Devexa Smart Search — Hyva-compatible autocomplete
 * Features: recent searches, popular terms, voice search, category browse,
 * recommended products, list/grid modes, sidebar layout
 */
$searchConfig = $block->getData('search_config');
if (!$searchConfig || !$searchConfig->isEnabled()) { return; }
$jsConfig = $searchConfig->getJsConfig();
$suggestUrl = $block->getUrl('smartsearch/ajax/suggest');
$searchUrl = $block->getUrl('catalogsearch/result');
?>
<script>
function devexaSmartSearch() {
    var config = <?= /* @noEscape */ json_encode($jsConfig) ?>;
    var suggestUrl = '<?= $block->escapeUrl($suggestUrl) ?>';
    var searchUrl = '<?= $block->escapeUrl($searchUrl) ?>';
    var maxRecent = 10;

    return {
        config: config, query: '', sections: [], total: 0,
        isOpen: false, isLoading: false, activeIndex: -1, debounceTimer: null,
        recentSearches: JSON.parse(localStorage.getItem('devexa_recent_searches') || '[]'),
        showInitial: false, initialLoaded: false, initialSections: [],
        isListening: false, speechSupported: !!window.SpeechRecognition || !!window.webkitSpeechRecognition,

        init() {
            document.addEventListener('click', (e) => { if (!this.$root.contains(e.target)) this.close(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.close(); });
        },

        onFocus() {
            if (this.sections.length > 0 && this.query.length >= config.minChars) {
                this.isOpen = true;
                this.showInitial = false;
            } else {
                this.showInitial = true;
                this.isOpen = true;
                if (!this.initialLoaded) this.loadInitial();
            }
        },

        async loadInitial() {
            try {
                var r = await fetch(suggestUrl + '?initial=1');
                var data = await r.json();
                this.initialSections = data.sections || [];
                this.initialLoaded = true;
            } catch (e) {}
        },

        onInput() {
            this.activeIndex = -1;
            if (this.query.length < config.minChars) {
                this.sections = [];
                this.showInitial = true;
                this.isOpen = true;
                return;
            }
            this.showInitial = false;
            clearTimeout(this.debounceTimer);
            this.debounceTimer = setTimeout(() => this.doSearch(), config.debounceMs);
        },

        async doSearch() {
            if (this.query.length < config.minChars) return;
            this.isLoading = true;
            try {
                var r = await fetch(suggestUrl + '?q=' + encodeURIComponent(this.query));
                var data = await r.json();
                this.sections = data.sections || [];
                this.total = data.total || 0;
                this.isOpen = true;
                this.showInitial = false;
            } catch (e) { this.sections = []; }
            finally { this.isLoading = false; }
        },

        close() { this.isOpen = false; this.showInitial = false; this.activeIndex = -1; },

        submitSearch() {
            if (this.query.length > 0) {
                this.addRecent(this.query);
                // Track search query for analytics
                if (window.DevexaAiTracker) {
                    window.DevexaAiTracker.trackEvent('search_query', { query: this.query });
                }
                window.location.href = searchUrl + '?q=' + encodeURIComponent(this.query);
            }
        },

        // Recent searches
        addRecent(term) {
            term = term.trim();
            if (!term) return;
            this.recentSearches = this.recentSearches.filter(s => s !== term);
            this.recentSearches.unshift(term);
            if (this.recentSearches.length > maxRecent) this.recentSearches.pop();
            localStorage.setItem('devexa_recent_searches', JSON.stringify(this.recentSearches));
        },
        removeRecent(term) {
            this.recentSearches = this.recentSearches.filter(s => s !== term);
            localStorage.setItem('devexa_recent_searches', JSON.stringify(this.recentSearches));
        },
        clearAllRecent() {
            this.recentSearches = [];
            localStorage.removeItem('devexa_recent_searches');
        },
        useRecent(term) {
            this.query = term;
            this.showInitial = false;
            this.doSearch();
        },

        // Voice search
        startVoice() {
            if (!this.speechSupported) return;
            var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            var recognition = new SpeechRecognition();
            recognition.lang = document.documentElement.lang || 'en-US';
            recognition.continuous = false;
            recognition.interimResults = false;
            this.isListening = true;
            recognition.onresult = (e) => {
                this.query = e.results[0][0].transcript;
                this.isListening = false;
                this.showInitial = false;
                this.doSearch();
            };
            recognition.onerror = () => { this.isListening = false; };
            recognition.onend = () => { this.isListening = false; };
            recognition.start();
        },

        onKeyDown(e) {
            if (!this.isOpen) return;
            var items = this.$root.querySelectorAll('[data-search-item]');
            if (e.key === 'ArrowDown') { e.preventDefault(); this.activeIndex = Math.min(this.activeIndex + 1, items.length - 1); if (items[this.activeIndex]) items[this.activeIndex].focus(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); this.activeIndex = Math.max(this.activeIndex - 1, 0); if (items[this.activeIndex]) items[this.activeIndex].focus(); }
            else if (e.key === 'Enter' && this.activeIndex >= 0 && items[this.activeIndex]) { e.preventDefault(); items[this.activeIndex].click(); }
        },

        highlight(text) {
            if (!this.query || !text) return text || '';
            var words = this.query.trim().split(/\s+/).filter(w => w.length > 1), result = text;
            words.forEach(function(word) { var esc = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); result = result.replace(new RegExp('(' + esc + ')', 'gi'), '<mark style="background:' + config.highlightColor + '20;color:' + config.highlightColor + ';padding:0 2px;border-radius:2px;">$1</mark>'); });
            return result;
        },
        getProductSections() { return this.sections.filter(s => s.type === 'products' || s.type === 'ai_recommendations' || s.type === 'recommended_products'); },
        getSidebarSections() { return this.sections.filter(s => s.type === 'categories' || s.type === 'pages'); },
        getBrowseCategories() { return this.sections.filter(s => s.type === 'browse_categories'); },
        gridCols() { return 'grid-cols-2 ' + ({ 2:'sm:grid-cols-2', 3:'sm:grid-cols-3', 4:'sm:grid-cols-4', 5:'sm:grid-cols-5' }[config.productColumns] || 'sm:grid-cols-4'); }
    };
}
</script>

<div x-data="devexaSmartSearch()" class="relative w-full" @keydown="onKeyDown">
    <!-- Search input -->
    <div class="relative" :class="{ 'z-50': isOpen }">
        <input type="text" x-model="query" @input="onInput" @focus="onFocus"
               @keydown.enter.prevent="activeIndex >= 0 ? null : submitSearch()"
               placeholder="<?= $block->escapeHtmlAttr(__('Search products, categories, pages...')) ?>"
               class="form-input w-full pl-10 pr-20 py-2.5 text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition"
               autocomplete="off">
        <!-- Search icon -->
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <!-- Right icons -->
        <div class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center gap-1">
            <!-- Loading -->
            <template x-if="isLoading"><svg class="w-4 h-4 text-primary-500 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg></template>
            <!-- Voice -->
            <template x-if="speechSupported && !isLoading">
                <button @click="startVoice" class="p-1.5 rounded-md transition" :class="isListening ? 'bg-red-100 text-red-500' : 'text-gray-400 hover:text-gray-600 hover:bg-gray-100'" :title="isListening ? '<?= $block->escapeHtmlAttr(__('Listening...')) ?>' : '<?= $block->escapeHtmlAttr(__('Voice search')) ?>'">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                </button>
            </template>
            <!-- Clear -->
            <template x-if="query.length > 0 && !isLoading">
                <button @click="query='';sections=[];showInitial=true;isOpen=true;" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-md transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </template>
        </div>
    </div>

    <!-- Popup: full width of page, positioned below the search input -->
    <div x-show="isOpen" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
         class="fixed z-50 left-0 right-0 bg-white shadow-2xl border-t border-gray-200 overflow-y-auto max-h-[70vh] sm:max-h-[80vh]"
         :style="'top:' + ($root.querySelector('input')?.getBoundingClientRect().bottom + 4 || 70) + 'px'">
      <div class="container mx-auto px-4 sm:px-6 py-4"
           :style="config.popupMaxWidth > 0 ? 'max-width:' + config.popupMaxWidth + 'px' : ''"
      >

        <!-- ==================== INITIAL STATE (on focus, no query) ==================== -->
        <template x-if="showInitial">
            <div>
                <!-- Recent searches -->
                <template x-if="recentSearches.length > 0">
                    <div class="px-4 py-3 border-b border-gray-100">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-semibold text-gray-500 uppercase"><?= $block->escapeHtml(__('Recent Searches')) ?></span>
                            <button @click="clearAllRecent" class="text-[10px] text-gray-400 hover:text-red-500 transition"><?= $block->escapeHtml(__('Clear all')) ?></button>
                        </div>
                        <div class="flex flex-wrap gap-1.5">
                            <template x-for="term in recentSearches" :key="term">
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-xs text-gray-700 cursor-pointer transition group">
                                    <span @click="useRecent(term)" x-text="term"></span>
                                    <button @click.stop="removeRecent(term)" class="text-gray-400 hover:text-red-500 transition">
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"/></svg>
                                    </button>
                                </span>
                            </template>
                        </div>
                    </div>
                </template>

                <!-- Browse categories (horizontal scroll with images) -->
                <template x-for="(section, si) in initialSections.filter(s => s.type === 'browse_categories')" :key="'ic-'+si">
                    <div class="px-4 py-3 border-b border-gray-100">
                        <span class="text-xs font-semibold text-gray-500 uppercase" x-text="section.title"></span>
                        <div class="flex gap-3 mt-2 overflow-x-auto pb-2 snap-x" style="scrollbar-width:none;-webkit-overflow-scrolling:touch;">
                            <template x-for="cat in section.items" :key="cat.id">
                                <a :href="cat.url" data-search-item class="flex-none w-28 sm:w-32 snap-start">
                                    <div class="bg-gray-50 overflow-hidden aspect-square flex items-center justify-center mb-1.5 hover:shadow-md transition">
                                        <template x-if="cat.image"><img :src="cat.image" :alt="cat.name" class="w-full h-full object-cover" loading="lazy"></template>
                                        <template x-if="!cat.image"><svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg></template>
                                    </div>
                                    <p class="text-[11px] text-gray-700 text-center leading-tight line-clamp-2" x-text="cat.name"></p>
                                </a>
                            </template>
                        </div>
                    </div>
                </template>

                <!-- Recommended products (carousel) -->
                <template x-for="(section, si) in initialSections.filter(s => s.type === 'recommended_products')" :key="'ip-'+si">
                    <div class="px-4 py-3">
                        <span class="text-xs font-semibold text-gray-500 uppercase" x-text="section.title"></span>
                        <div class="flex gap-3 mt-2 overflow-x-auto pb-2 snap-x" style="scrollbar-width:none;">
                            <template x-for="item in section.items" :key="item.id">
                                <a :href="item.url" data-search-item class="flex-none w-36 sm:w-40 snap-start bg-white border border-gray-100 hover:shadow-md transition overflow-hidden">
                                    <template x-if="item.image"><img :src="item.image" :alt="item.name" class="w-full aspect-square object-contain bg-gray-50" loading="lazy"></template>
                                    <div class="p-2">
                                        <p class="text-[11px] text-gray-900 leading-tight line-clamp-2 mb-1" x-text="item.name"></p>
                                        <template x-if="item.price"><span class="text-xs font-bold text-primary-600" x-text="item.price"></span></template>
                                    </div>
                                </a>
                            </template>
                        </div>
                    </div>
                </template>
            </div>
        </template>

        <!-- ==================== SEARCH RESULTS ==================== -->
        <template x-if="!showInitial && sections.length > 0">
            <div>
                <!-- TOP: categories/pages pills -->
                <template x-if="config.sidebarPosition === 'top' && getSidebarSections().length > 0">
                    <div class="border-b border-gray-100">
                        <template x-for="(section, si) in getSidebarSections()" :key="'top-'+si">
                            <div class="px-4 py-2">
                                <span class="text-[10px] font-semibold text-gray-400 uppercase" x-text="section.title"></span>
                                <div class="flex flex-wrap gap-1.5 mt-1">
                                    <template x-for="item in section.items" :key="item.id">
                                        <a :href="item.url" data-search-item class="inline-flex items-center gap-1 px-2.5 py-1 bg-gray-50 hover:bg-primary-50 hover:text-primary-700 rounded-full text-xs text-gray-600 transition">
                                            <span x-html="highlight(item.name || item.title)"></span>
                                        </a>
                                    </template>
                                </div>
                            </div>
                        </template>
                    </div>
                </template>

                <!-- Main: sidebar + products -->
                <div :class="config.sidebarPosition !== 'top' && getSidebarSections().length > 0 ? 'sm:flex' : ''">
                    <!-- LEFT/RIGHT sidebar -->
                    <template x-if="config.sidebarPosition !== 'top' && getSidebarSections().length > 0">
                        <div :class="config.sidebarPosition === 'right' ? 'order-2 border-l' : 'order-1 border-r'" class="w-full sm:w-44 shrink-0 border-gray-100 bg-gray-50/50">
                            <template x-for="(section, si) in getSidebarSections()" :key="'sb-'+si">
                                <div>
                                    <div class="px-3 py-2 text-[10px] font-semibold text-gray-400 uppercase border-b border-gray-100" x-text="section.title"></div>
                                    <template x-for="item in section.items" :key="item.id">
                                        <a :href="item.url" data-search-item class="flex items-center gap-2 px-3 py-2 text-xs text-gray-600 hover:bg-white hover:text-primary-700 transition border-b border-gray-50 last:border-0">
                                            <span class="truncate" x-html="highlight(item.name || item.title)"></span>
                                        </a>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>

                    <!-- Products -->
                    <div :class="config.sidebarPosition !== 'top' && getSidebarSections().length > 0 ? (config.sidebarPosition === 'right' ? 'order-1' : 'order-2') + ' flex-1 min-w-0' : 'w-full'">
                        <template x-for="(section, si) in getProductSections()" :key="'p-'+si">
                            <div>
                                <div class="px-4 py-2 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                                    <span class="text-[10px] font-semibold text-gray-400 uppercase" x-text="section.title"></span>
                                    <span class="text-[10px] text-gray-400" x-text="section.count"></span>
                                </div>
                                <!-- GRID -->
                                <template x-if="config.productDisplay === 'grid'">
                                    <div class="p-2 grid gap-2" :class="gridCols()">
                                        <template x-for="item in section.items" :key="item.id">
                                            <a :href="item.url" data-search-item class="block bg-white border border-gray-100 hover:shadow-md hover:border-primary-200 transition overflow-hidden group">
                                                <template x-if="config.showImage && (item.image_grid || item.image)"><img :src="item.image_grid || item.image" :alt="item.name" class="w-full aspect-square object-contain bg-gray-50 group-hover:scale-105 transition-transform" loading="lazy"></template>
                                                <div class="p-2">
                                                    <p class="text-[11px] font-medium text-gray-900 leading-tight line-clamp-2 mb-1" x-html="highlight(item.name)"></p>
                                                    <div class="flex items-center gap-1">
                                                        <template x-if="config.showPrice && item.price"><span class="text-xs font-bold text-primary-600" x-text="item.price"></span></template>
                                                        <template x-if="item.ai"><span class="px-1 py-0.5 rounded text-[8px] font-semibold bg-primary-100 text-primary-700">AI</span></template>
                                                    </div>
                                                </div>
                                            </a>
                                        </template>
                                    </div>
                                </template>
                                <!-- LIST -->
                                <template x-if="config.productDisplay !== 'grid'">
                                    <div>
                                        <template x-for="item in section.items" :key="item.id">
                                            <a :href="item.url" data-search-item class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 focus:bg-gray-50 outline-none transition border-b border-gray-50 last:border-0">
                                                <template x-if="config.showImage && (item.image_thumb || item.image)"><img :src="item.image_thumb || item.image" :alt="item.name" class="w-12 h-12 object-contain rounded bg-gray-50 shrink-0" loading="lazy"></template>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate" x-html="highlight(item.name)"></p>
                                                    <template x-if="config.showSku && item.sku"><p class="text-xs text-gray-400" x-text="'SKU: '+item.sku"></p></template>
                                                </div>
                                                <template x-if="config.showPrice && item.price"><span class="text-sm font-bold text-primary-600 shrink-0" x-text="item.price"></span></template>
                                                <template x-if="item.ai"><span class="px-1.5 py-0.5 rounded text-[10px] font-semibold bg-primary-100 text-primary-700 shrink-0">AI</span></template>
                                            </a>
                                        </template>
                                    </div>
                                </template>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- Browse categories (no results fallback) -->
                <template x-for="(section, si) in getBrowseCategories()" :key="'bc-'+si">
                    <div class="px-4 py-3 border-t border-gray-100 bg-gray-50/50">
                        <span class="text-xs font-semibold text-gray-500" x-text="section.title"></span>
                        <div class="flex gap-3 mt-2 overflow-x-auto pb-1 snap-x" style="scrollbar-width:none;">
                            <template x-for="cat in section.items" :key="cat.id">
                                <a :href="cat.url" data-search-item class="flex-none flex items-center gap-2 px-3 py-2 bg-white border border-gray-200 hover:border-primary-300 hover:shadow-sm transition snap-start">
                                    <template x-if="cat.image"><img :src="cat.image" :alt="cat.name" class="w-8 h-8 rounded object-cover" loading="lazy"></template>
                                    <span class="text-xs text-gray-700 whitespace-nowrap" x-text="cat.name"></span>
                                </a>
                            </template>
                        </div>
                    </div>
                </template>

                <!-- View all results -->
                <template x-if="total > 0 && getProductSections().length > 0">
                    <a @click="submitSearch()" class="block px-4 py-3 text-center text-sm font-medium text-primary-600 hover:bg-primary-50 cursor-pointer transition border-t border-gray-100">
                        <?= $block->escapeHtml(__('View all results for')) ?> "<span x-text="query"></span>"
                    </a>
                </template>
            </div>
        </template>

        <!-- Listening indicator -->
        <template x-if="isListening">
            <div class="px-4 py-6 text-center">
                <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-3 animate-pulse">
                    <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                </div>
                <p class="text-sm text-gray-500"><?= $block->escapeHtml(__('Listening...')) ?></p>
            </div>
        </template>
      </div><!-- /container -->
    </div><!-- /popup -->

    <!-- Overlay -->
    <div x-show="isOpen" x-cloak @click="close()" class="fixed inset-0 z-40 bg-black/20" x-transition></div>
</div>
